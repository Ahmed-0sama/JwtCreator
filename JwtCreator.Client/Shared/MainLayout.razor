@inherits LayoutComponentBase

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Geist:wght@400;500;600&display=swap" rel="stylesheet" />

<div class="shell">

    <div class="header">
        <span class="header-logo">JWT Studio</span>
        <span class="header-badge">HS256</span>
    </div>

    <div class="body">
        <nav class="tabs">
            <NavLink class="tab" href="/" Match="NavLinkMatch.All">Generate</NavLink>
            <NavLink class="tab" href="/decode">Decode</NavLink>
            <NavLink class="tab" href="/tamper">Tamper</NavLink>
        </nav>

        <main class="content">
            @Body
        </main>
    </div>

</div>

<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    .shell {
        --bg:             #ffffff;
        --bg1:            #fafafa;
        --bg2:            #f4f4f4;
        --bg3:            #ececec;
        --border:         #e4e4e4;
        --border2:        #d0d0d0;
        --text:           #111111;
        --muted:          #888888;
        --muted2:         #c4c4c4;
        --accent:         #2563eb;
        --accent-light:   #eff6ff;
        --accent-border:  #bfdbfe;
        --red:            #dc2626;
        --red-light:      #fef2f2;
        --green:          #16a34a;
        --amber:          #d97706;
        --font-mono:      'IBM Plex Mono', 'Fira Code', monospace;
        --font-sans:      'Geist', system-ui, sans-serif;

        font-family: var(--font-sans);
        font-size: 14px;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
    }

    /* ── Header ── */
    .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.9rem 2rem;
        border-bottom: 1px solid var(--border);
        background: var(--bg);
        position: sticky;
        top: 0;
        z-index: 10;
    }
    .header-logo {
        font-size: 15px;
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--text);
    }
    .header-badge {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--muted);
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 3px 8px;
        letter-spacing: 0.04em;
    }

    /* ── Body + tabs ── */
    .body {
        max-width: 700px;
        margin: 0 auto;
        padding: 0 1.75rem 4rem;
    }

    .tabs {
        display: flex;
        border-bottom: 1px solid var(--border);
        margin-bottom: 2.25rem;
    }
    .tab {
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        color: var(--muted);
        cursor: pointer;
        font-family: var(--font-sans);
        font-size: 13px;
        font-weight: 500;
        padding: 0.9rem 1.25rem;
        margin-bottom: -1px;
        text-decoration: none;
        transition: color 0.15s, border-color 0.15s;
        display: inline-block;
    }
    .tab:hover { color: var(--text); }
    .tab.active {
        color: var(--accent);
        border-bottom-color: var(--accent);
    }

    /* ── Content ── */
    .content { width: 100%; }

    /* ── Pane header ── */
    .pane-header { margin-bottom: 1.75rem; }
    .pane-cmd {
        display: block;
        font-size: 18px;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin-bottom: 0.2rem;
    }
    .pane-desc { font-size: 13px; color: var(--muted); }

    /* ── Fields ── */
    .field-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .field { display: flex; flex-direction: column; gap: 0.35rem; }
    .span2 { grid-column: 1 / -1; }

    .field-label {
        font-size: 12px;
        font-weight: 500;
        color: var(--text);
    }
    .field-label .muted {
        color: var(--muted);
        font-weight: 400;
    }

    .field-input {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 7px;
        color: var(--text);
        font-family: var(--font-sans);
        font-size: 13px;
        padding: 0.55rem 0.8rem;
        outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
        width: 100%;
        appearance: none;
    }
    .field-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }
    .field-input::placeholder { color: var(--muted2); }
    .field-input.secret { font-family: var(--font-mono); letter-spacing: 0.08em; }
    .field-textarea { resize: vertical; line-height: 1.6; }
    .code-area { font-family: var(--font-mono); font-size: 12px; line-height: 1.65; }

    /* ── Buttons ── */
    .run-btn {
        background: var(--accent);
        border: none;
        border-radius: 7px;
        color: #fff;
        cursor: pointer;
        font-family: var(--font-sans);
        font-size: 13px;
        font-weight: 500;
        padding: 0.6rem 1.25rem;
        transition: opacity 0.15s, transform 0.1s;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }
    .run-btn:hover:not(:disabled) { opacity: 0.87; }
    .run-btn:active:not(:disabled) { transform: scale(0.98); }
    .run-btn:disabled { opacity: 0.35; cursor: not-allowed; }

    .ghost-btn {
        background: var(--bg);
        border: 1px solid var(--border2);
        border-radius: 7px;
        color: var(--text);
        cursor: pointer;
        font-family: var(--font-sans);
        font-size: 13px;
        font-weight: 500;
        padding: 0.55rem 1rem;
        transition: border-color 0.15s, color 0.15s;
    }
    .ghost-btn:hover { border-color: var(--accent); color: var(--accent); }

    .copy-btn {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 5px;
        color: var(--muted);
        cursor: pointer;
        font-family: var(--font-sans);
        font-size: 12px;
        font-weight: 500;
        padding: 0.35rem 0.85rem;
        transition: all 0.15s;
    }
    .copy-btn:hover {
        border-color: var(--accent-border);
        color: var(--accent);
        background: var(--accent-light);
    }

    /* ── Error ── */
    .err-line {
        background: var(--red-light);
        border: 1px solid #fecaca;
        border-radius: 7px;
        color: var(--red);
        font-size: 13px;
        margin-top: 0.85rem;
        padding: 0.65rem 0.9rem;
    }
    .err-prefix { font-weight: 600; margin-right: 0.3rem; }

    /* ── Output block ── */
    .output-block {
        margin-top: 1.75rem;
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
    }
    .output-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--bg1);
        border-bottom: 1px solid var(--border);
        padding: 0.6rem 1rem;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .output-label {
        font-size: 11px;
        font-weight: 600;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.07em;
    }
    .output-meta {
        font-size: 11px;
        font-family: var(--font-mono);
        color: var(--muted);
    }
    .output-footer {
        display: flex;
        gap: 0.5rem;
        padding: 0.75rem 1rem;
        background: var(--bg1);
        border-top: 1px solid var(--border);
        flex-wrap: wrap;
    }

    .token-line {
        padding: 1rem;
        word-break: break-all;
        line-height: 1.75;
        font-family: var(--font-mono);
        font-size: 11.5px;
        background: var(--bg);
    }

    /* ── Badges ── */
    .badge-row { display: flex; gap: 0.4rem; flex-wrap: wrap; }
    .badge {
        font-size: 11px;
        font-weight: 500;
        padding: 2px 9px;
        border-radius: 20px;
    }
    .badge-ok   { background: #dcfce7; color: #15803d; }
    .badge-err  { background: #fee2e2; color: #b91c1c; }
    .badge-warn { background: #fef9c3; color: #92400e; }

    /* ── JSON sections ── */
    .section-row {
        padding: 0.6rem 1rem 0.15rem;
        background: var(--bg1);
        border-top: 1px solid var(--border);
    }
    .section-key { font-size: 11px; font-weight: 600; letter-spacing: 0.04em; }
    .json-pre {
        background: var(--bg);
        border-left: 3px solid var(--border);
        font-family: var(--font-mono);
        font-size: 11.5px;
        line-height: 1.65;
        margin: 0;
        padding: 0.65rem 1rem 0.65rem 1.1rem;
        white-space: pre-wrap;
        word-break: break-all;
        color: #555;
        overflow-x: auto;
    }
    .red-left   { border-left-color: var(--red); }
    .amber-left { border-left-color: var(--amber); }
    .green-left { border-left-color: var(--green); }

    /* ── Token colors ── */
    .t-red   { color: var(--red); }
    .t-amber { color: var(--amber); }
    .t-green { color: var(--green); }
    .t-dim   { color: var(--muted2); }
    .muted   { color: var(--muted); }

    /* ── Tamper steps ── */
    .step-row {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        margin-bottom: 0.65rem;
    }
    .step-pill {
        background: var(--text);
        color: #fff;
        font-size: 10px;
        font-weight: 600;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .step-text { font-size: 13px; color: var(--muted); font-weight: 500; }

    .rule {
        border: none;
        border-top: 1px solid var(--border);
        margin: 1.75rem 0;
    }

    /* ── Responsive ── */
    @@media (max-width: 560px) {
        .header { padding: 0.85rem 1.25rem; }
        .body { padding: 0 1.25rem 3rem; }
        .field-grid { grid-template-columns: 1fr; }
        .span2 { grid-column: 1; }
        .tab { padding: 0.8rem 1rem; }
    }
</style>
